# ===================================================================
# ClimaLens :: Secrets Template
# ===================================================================
# Copy this file to application-secrets.yml (gitignored), fill in your keys.
# NEVER commit real API keys to version control.
# ===================================================================

weatherapi:
  base-url: https://api.weatherapi.com/v1
  api-key: ${WEATHERAPI_KEY:YOUR_WEATHERAPI_COM_KEY}

openweather:
  base-url: https://api.openweathermap.org/data/2.5
  onecall-url: https://api.openweathermap.org/data/3.0/onecall
  api-key: ${OPENWEATHER_KEY:YOUR_OPENWEATHERMAP_KEY}

tomorrowio:
  base-url: https://api.tomorrow.io/v4
  api-key: ${TOMORROWIO_KEY:YOUR_TOMORROWIO_KEY}

nasa:
  base-url: https://api.nasa.gov
  power-url: https://power.larc.nasa.gov/api
  eonet-url: https://eonet.gsfc.nasa.gov/api/v3
  api-key: ${NASA_KEY:DEMO_KEY}