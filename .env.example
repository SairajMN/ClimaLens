# ===================================================================
# ClimaLens :: Environment Variables Template
# ===================================================================
# Copy this file to .env (gitignored) and fill in your values.
# Used by docker-compose.yml for service configuration.
# NEVER commit real secrets to version control.
# ===================================================================

# PostgreSQL
POSTGRES_DB=climalens
POSTGRES_USER=climalens
POSTGRES_PASSWORD=climalens

# Redis
REDIS_PORT=6379

# App port
APP_PORT=8080

# API Keys (required for ingestion module functionality)
WEATHERAPI_KEY=
OPENWEATHER_KEY=
TOMORROWIO_KEY=
NASA_KEY=DEMO_KEY

# JWT Secret (generate: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_AT_LEAST_256_BITS

# SMTP (optional, for email alerts)
SMTP_USERNAME=
SMTP_PASSWORD=